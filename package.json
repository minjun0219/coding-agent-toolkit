{
  "name": "agent-toolkit",
  "private": true,
  "version": "0.1.0",
  "description": "Agent Toolkit MVP - Notion cache + MCP gateway + opencode plugin (Bun)",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "gateway": "bun run packages/agent-toolkit-mcp-gateway/src/cli.ts",
    "plugin": "bun run packages/agent-toolkit-opencode-plugin/src/cli.ts",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json",
    "test": "bun test"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/bun": "^1.1.0",
    "@agent-toolkit/core": "*",
    "@agent-toolkit/mcp-gateway": "*"
  }
}
