{
  "name": "agent-toolkit",
  "version": "0.1.0",
  "description": "opencode plugin: Notion page cache + skill (Bun)",
  "license": "MIT",
  "author": "Minjun Kim",
  "private": true,
  "main": "./.opencode/plugins/agent-toolkit-server.ts",
  "exports": {
    ".": {
      "import": "./.opencode/plugins/agent-toolkit-server.ts"
    },
    "./server": {
      "import": "./.opencode/plugins/agent-toolkit-server.ts"
    }
  },
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "check": "biome check .",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "bun test ./lib ./.opencode ./server",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/plugin": "1.14.35",
    "mysql2": "^3.11.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "^1.1.0",
    "typescript": "^5.4.5"
  }
}
