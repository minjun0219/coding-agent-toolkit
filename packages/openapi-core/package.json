{
  "name": "@minjun0219/openapi-core",
  "version": "0.3.0",
  "description": "Shared OpenAPI / Swagger spec cache + endpoint search + handler core. Consumed by openapi-mcp standalone CLI and the two agent-toolkit plugin hosts (Claude Code, opencode). Workspace-internal — not yet published to npm.",
  "license": "MIT",
  "author": "Minjun Kim",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./adapter": "./src/adapter.ts",
    "./handlers": "./src/handlers.ts",
    "./openapi-registry": "./src/openapi-registry.ts",
    "./registry": "./src/registry.ts",
    "./schema": "./src/schema.ts",
    "./toolkit-config": "./src/toolkit-config.ts",
    "./indexer": "./src/indexer.ts",
    "./config-loader": "./src/config-loader.ts",
    "./logger": "./src/logger.ts",
    "./cache": "./src/cache.ts",
    "./fetcher": "./src/fetcher.ts",
    "./filter": "./src/filter.ts"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "js-yaml": "^4.1.0",
    "openapi-types": "^12.1.3",
    "pino": "^9.5.0",
    "swagger2openapi": "^7.0.8",
    "zod": "^4.4.3"
  }
}
