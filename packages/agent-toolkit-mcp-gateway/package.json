{
  "name": "@agent-toolkit/mcp-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Local MCP gateway that caches and proxies remote Notion MCP",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts"
  },
  "bin": {
    "agent-toolkit-gateway": "src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "typecheck": "bun x tsc --noEmit"
  },
  "dependencies": {
    "@agent-toolkit/core": "*"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
