{
  "name": "openapi-mcp",
  "version": "0.3.0",
  "description": "Standalone stdio MCP server for browsing internal OpenAPI / Swagger specs (cache + endpoint search + tag list). 7 tools, host-agnostic — works with any MCP client (Claude Code, Cursor, Continue, …) via stdio. Subset of the agent-toolkit set.",
  "license": "MIT",
  "author": "Minjun Kim",
  "homepage": "https://github.com/minjun0219/agent-toolkit/tree/main/packages/openapi-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minjun0219/agent-toolkit.git",
    "directory": "packages/openapi-mcp"
  },
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "openapi-mcp": "./bin/openapi-mcp"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "bin",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "openapi",
    "swagger",
    "mcp",
    "stdio",
    "spec",
    "bun"
  ],
  "dependencies": {
    "@minjun0219/openapi-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
